---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutSection from '../components/sections/AboutSection.astro';

const home = await getEntry('marketing', 'home');
if (!home) {
	throw new Error('Missing src/content/marketing/home.md');
}
const { Content: HomeAbout } = await render(home);

const title = `Team — ${home.data.seo.title}`;

const advisors = [
	{
		name: 'Advisory Member 01',
		role: 'Strategic Growth Advisor',
		bio: 'Supports portfolio expansion strategy, market entry planning, and operating model design.',
	},
	{
		name: 'Advisory Member 02',
		role: 'Investment & Governance Advisor',
		bio: 'Guides investment discipline, governance structures, and long-term value creation frameworks.',
	},
	{
		name: 'Advisory Member 03',
		role: 'Technology & Operations Advisor',
		bio: 'Advises teams on execution cadence, digital enablement, and scalable operating processes.',
	},
];
---

<BaseLayout title={title} description={home.data.seo.description}>
	<main>
		<AboutSection
			sectionId="team"
			heading="Team"
			points={home.data.aboutPoints}
			aboutImage={home.data.aboutImage}
			aboutImageAlt={home.data.aboutImageAlt}
			profile={home.data.aboutProfile}
		>
			<HomeAbout />
		</AboutSection>

		<section id="advisors" class="border-b border-neutral-200/90 bg-stone-50">
			<div class="mx-auto max-w-7xl px-5 py-10 sm:px-8 lg:px-12 lg:py-12">
				<h2 class="font-display text-2xl font-medium tracking-tight text-neutral-900 sm:text-3xl">Advisors</h2>
				<p class="mt-3 max-w-2xl text-sm leading-relaxed text-neutral-600 sm:text-base">
					Our advisory group brings domain expertise across investing, governance, and operations.
				</p>

				<div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
					{
						advisors.map((advisor) => (
							<article class="rounded-lg border border-neutral-200/90 bg-white p-5 shadow-sm">
								<h3 class="font-display text-xl font-medium text-neutral-900">{advisor.name}</h3>
								<p class="mt-1 text-sm font-medium text-neutral-700">{advisor.role}</p>
								<p class="mt-3 text-sm leading-relaxed text-neutral-600">{advisor.bio}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
