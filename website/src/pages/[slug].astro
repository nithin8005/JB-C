---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('marketing');
	return entries
		.filter((e) => e.id !== 'home')
		.map((e) => ({
			params: { slug: e.id },
			props: { entry: e },
		}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.seo.title} description={entry.data.seo.description}>
	<main class="border-b border-neutral-200/90 bg-white">
		<article class="md-article mx-auto max-w-3xl px-5 py-12 sm:px-8 lg:px-12 lg:py-16" data-reveal>
			<h1 class="font-display text-3xl font-medium text-neutral-900 sm:text-4xl">{entry.data.seo.title}</h1>
			<p class="mt-3 text-sm text-neutral-600 sm:text-base">{entry.data.seo.description}</p>
			<div class="mt-10 text-neutral-700">
				<Content />
			</div>
		</article>
	</main>
</BaseLayout>

<style is:global>
	.md-article :where(h2) {
		margin-top: 2.5rem;
		margin-bottom: 0.75rem;
		font-family: var(--font-heading, var(--font-display), ui-serif, Georgia, serif);
		font-size: 1.375rem;
		font-weight: 600;
		color: #171717;
	}
	.md-article :where(h2):first-of-type {
		margin-top: 0;
	}
	.md-article :where(p) {
		margin: 0 0 1rem;
		line-height: 1.7;
		font-size: 1rem;
	}
	.md-article :where(ul) {
		margin: 0 0 1rem;
		padding-left: 1.25rem;
		list-style-type: disc;
	}
	.md-article :where(li) {
		margin: 0.35rem 0;
	}
	.md-article :where(strong) {
		font-weight: 600;
		color: #171717;
	}
	.md-article :where(a) {
		color: #171717;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.md-article :where(table) {
		width: 100%;
		margin: 0 0 1rem;
		border-collapse: collapse;
		font-size: 0.9375rem;
	}
	.md-article :where(th, td) {
		border: 1px solid #e5e5e5;
		padding: 0.5rem 0.75rem;
		text-align: left;
		vertical-align: top;
	}
	.md-article :where(th) {
		font-weight: 600;
		color: #171717;
		background: #fafafa;
	}
</style>
