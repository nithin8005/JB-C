---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import LocationsSection from '../components/sections/LocationsSection.astro';
import WhoWeWorkWithSection from '../components/sections/WhoWeWorkWithSection.astro';
import PartnersSection from '../components/sections/PartnersSection.astro';
import { requireHomeBlock } from '../lib/homeBlocks';

const home = await getEntry('marketing', 'home');
if (!home) {
	throw new Error('Missing src/content/marketing/home.md'); 	
}
const heroEntry = await requireHomeBlock('hero');
if (heroEntry.data.kind !== 'hero') {
	throw new Error('Invalid hero block');
}
const hero = heroEntry.data;

const locationsEntry = await requireHomeBlock('locations');
if (locationsEntry.data.kind !== 'locations') {
	throw new Error('Invalid locations block');
}
const locations = locationsEntry.data;

const partnersEntry = await requireHomeBlock('partners');
if (partnersEntry.data.kind !== 'partners') {
	throw new Error('Invalid partners block');
}
const partners = partnersEntry.data;
---

<BaseLayout title={home.data.seo.title} description={home.data.seo.description}>
	<main>
		<HeroSection
			title={hero.title}
			description={hero.description}
			ctaLabel={hero.ctaLabel}
			ctaHref={hero.ctaHref}
			videoWebm={hero.videoWebm}
			videoMp4={hero.videoMp4}
			videoPoster={hero.videoPoster}
			backgroundImage={hero.backgroundImage}
			backgroundImageAlt={hero.backgroundImageAlt}
		/>
		<LocationsSection
			title={locations.title}
			intro={locations.intro}
			locations={locations.locations}
		/>
		<WhoWeWorkWithSection />
		<PartnersSection
			title={partners.title}
			intro={partners.intro}
			gridImage={partners.gridImage}
			gridImageAlt={partners.gridImageAlt}
			groups={partners.groups ?? []}
		/>
	</main>
</BaseLayout>
