---

import { withBase } from '../lib/withBase';

interface LinkItem {

	label: string;

	href: string;

}



interface Column {

	title: string;

	links: LinkItem[];

}



interface Props {

	siteName: string;

	tagline: string;

	legalName: string;

	copyrightEntity: string;

	footerContactEmail?: string;

}



const { siteName, tagline, legalName, copyrightEntity, footerContactEmail } = Astro.props;



const columns: Column[] = [

	{

		title: 'Solutions',

		links: [

			{ label: 'Overview', href: '/#about' },

			{ label: 'Portfolio', href: '/portfolio' },

			{ label: 'Affiliates', href: '/affiliates' },

			{ label: 'Real Assets', href: '/real-assets' },
		],

	},

	{

		title: 'Team',

		links: [

			{ label: 'Company overview', href: '/#about' },

			{ label: 'Leadership and careers', href: '/careers' },

			{ label: 'Start the conversation', href: '/contact' },

		],

	},

];



const startHereLinks: LinkItem[] = [

	{ label: 'Contact us', href: '/contact' },

	...(footerContactEmail

		? [{ label: footerContactEmail, href: `mailto:${footerContactEmail}` } satisfies LinkItem]

		: []),

	{ label: 'Locations', href: '/#locations' },

];



const linkClass = 'text-[13px] leading-snug text-neutral-600 transition-colors hover:text-neutral-950';

const headClass = 'text-sm font-semibold tracking-tight text-neutral-950';

---



<footer class="border-t border-neutral-200/70 bg-[#f9f9f7]">

	<div class="mx-auto max-w-6xl px-5 py-10 sm:px-8 lg:px-12 lg:py-12">

		<div

			class="grid grid-cols-1 items-start gap-8 border-b border-neutral-200/80 pb-10 sm:grid-cols-2 sm:gap-x-10 sm:gap-y-9 lg:grid-cols-[minmax(0,22rem)_repeat(3,minmax(0,1fr))] lg:gap-x-5 lg:gap-y-0 xl:gap-x-6"

		>

			<div class="flex min-w-0 flex-col items-start self-start text-left sm:col-span-2 lg:col-span-1 lg:max-w-[22rem]">

				<a href={withBase('/')} class="text-neutral-950 no-underline">

					<span class="font-display text-base font-semibold tracking-tight">{siteName}</span>

				</a>

				<p class="mt-3 max-w-[22rem] text-left text-[13px] leading-snug text-neutral-600 whitespace-pre-line lg:max-w-none">
					{tagline.trim()}
				</p>

			</div>



			{

				columns.map((col) => (

					<div class="min-w-0">

						<p class={headClass}>{col.title}</p>

						<ul class="mt-3 space-y-1.5" role="list">

							{col.links.map(({ label, href }) => (

								<li>

									<a href={withBase(href)} class:list={[linkClass, href.startsWith('mailto:') && 'break-all']}>

										{label}

									</a>

								</li>

							))}

						</ul>

					</div>

				))

			}



			<div class="min-w-0 lg:col-span-1">

				<p class={headClass}>Start here</p>

				<ul class="mt-3 space-y-2.5" role="list">

					{

						startHereLinks.map(({ label, href }) => (

							<li>

								<a href={withBase(href)} class:list={[linkClass, href.startsWith('mailto:') && 'break-all']}>

									{label}

								</a>

							</li>

						))

					}

				</ul>

			</div>

		</div>



		<div class="mt-8 flex flex-col gap-4 text-xs text-neutral-500 sm:flex-row sm:items-start sm:justify-between sm:gap-6">

			<p class="shrink-0">

				© {new Date().getFullYear()}

				{copyrightEntity}. All rights reserved.

			</p>

			<div class="flex min-w-0 flex-col gap-2 sm:items-end sm:text-right">

				<p class="text-neutral-500">

					<span class="text-neutral-600">Legal name:</span>

					{legalName}

					<span class="mx-2 text-neutral-300" aria-hidden="true">·</span>

					<a href={withBase('/')} class="text-neutral-600 underline-offset-2 hover:text-neutral-900 hover:underline">

						Company

					</a>

				</p>

				<nav class="flex flex-wrap gap-x-2 gap-y-1 text-neutral-600" aria-label="Legal">

					<a href={withBase('/privacy')} class="underline-offset-2 hover:text-neutral-900 hover:underline">Privacy</a>

					<span class="text-neutral-300" aria-hidden="true">·</span>

					<a href={withBase('/cookies')} class="underline-offset-2 hover:text-neutral-900 hover:underline">Cookies</a>

					<span class="text-neutral-300" aria-hidden="true">·</span>

					<a href={withBase('/terms')} class="underline-offset-2 hover:text-neutral-900 hover:underline">Terms</a>

					<span class="text-neutral-300" aria-hidden="true">·</span>

					<a href={withBase('/disclaimer')} class="underline-offset-2 hover:text-neutral-900 hover:underline">Disclaimer</a>

				</nav>

			</div>

		</div>

	</div>

</footer>


