---
import { withBase } from '../../lib/withBase';

interface PartnerItem {
	name: string;
	logo: string;
	href?: string;
	/** Smaller max height for wide marks (set in content). */
	compactLogo?: boolean;
	/** Slightly larger max height when the mark reads small (set in content). */
	largeLogo?: boolean;
}

interface PartnerGroup {
	title: string;
	items: PartnerItem[];
}

interface Props {
	title: string;
	intro?: string;
	/** Full-width banner of all logos; when set, `groups` are not rendered. */
	gridImage?: string;
	gridImageAlt?: string;
	groups?: PartnerGroup[];
}

const { title, intro, gridImage, gridImageAlt, groups = [] } = Astro.props;

function assetSrc(path: string): string {
	const u = (path ?? '').trim();
	if (!u) return u;
	if (/^https?:\/\//i.test(u)) return u;
	return withBase(u.startsWith('/') ? u : `/${u}`);
}

const bannerSrc = gridImage?.trim() ? assetSrc(gridImage) : '';
const useBanner = Boolean(bannerSrc);

/** Equal columns and uniform row/column gaps at every breakpoint. */
function gridClassForCount(count: number): string {
	if (count >= 8) {
		/* Mobile-first: balanced card spacing; expand to 4/8 cols on larger screens */
		return 'grid grid-cols-4 gap-2 sm:gap-4 sm:grid-cols-4 lg:grid-cols-8';
	}
	if (count === 3) {
		return 'grid grid-cols-2 gap-3 sm:gap-4 sm:grid-cols-3 lg:mx-auto lg:max-w-4xl';
	}
	return 'grid grid-cols-2 gap-3 sm:gap-4 sm:grid-cols-3 lg:grid-cols-3';
}
---

<section id="partners" class="scroll-mt-20 border-b border-neutral-200/90 bg-stone-50">
	<div class="mx-auto max-w-6xl px-5 py-6 sm:px-8 sm:py-7 lg:px-12 lg:py-8">
		<h2 class="text-left font-display text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">
			{title}
		</h2> 
		{
			intro && (
				<p class="mt-2 max-w-2xl text-left text-sm leading-relaxed text-neutral-600 sm:text-[0.9375rem]">
					{intro}
				</p>
			)
		}

		{
			useBanner ? (
				<div class="mt-6 sm:mt-8">
					<img
						src={bannerSrc}
						alt={gridImageAlt ?? ''}
						class="mx-auto block w-full max-w-5xl object-contain"
						loading="eager"
						decoding="async"
					/>
				</div>
			) : (
				<div class="mt-8 space-y-9 sm:mt-10 sm:space-y-10">
					{groups.map((group) => (
						<div>
							{group.title?.trim() ? (
								<h3 class="mb-6 text-left text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">
									{group.title}
								</h3>
							) : null}
							<ul class:list={[gridClassForCount(group.items.length), 'min-w-0 list-none items-stretch']}>
								{group.items.map((item) => {
									const src = assetSrc(item.logo);
								const isTechEducation = (group.title ?? '').trim().toLowerCase() === 'technology & education';
								const itemName = (item.name ?? '').trim().toLowerCase();
								const isIbmOrCoursera = ['ibm', 'coursera'].includes(itemName);
								const isLarsen = itemName === 'larsen & toubro';
								/*
								 * Below `sm`: identical cell height and logo bounds for every partner (alignment + parity).
								 * From `sm`: preserve compact/wide/tall tuning from content flags.
								 */
								const cellTall = item.largeLogo;
								const cellFrame = [
									isTechEducation
										? 'flex h-14 w-full min-w-0 shrink-0 items-center justify-center overflow-hidden px-2 py-1 sm:h-16 sm:p-2'
										: 'flex h-16 w-full min-w-0 shrink-0 items-center justify-center overflow-hidden px-2 py-1.5 sm:h-18 sm:p-2',
									cellTall ? 'sm:h-20 lg:h-21' : 'sm:h-18 lg:h-19',
								].join(' ');
								/** Taller cap on phones helps wide wordmarks (IBM, EC-Council) read closer to square marks. */
								let imgClass = item.compactLogo
									? isTechEducation
										? 'mx-auto block h-7 w-full max-h-7 max-w-[76%] object-contain object-center sm:h-8 sm:w-auto sm:max-h-8 sm:max-w-[80%] lg:h-8 lg:max-h-8 lg:max-w-[82%]'
										: 'mx-auto block h-11 w-full max-h-11 max-w-full object-contain object-center sm:h-9 sm:w-auto sm:max-h-9 sm:max-w-[88%] lg:h-10 lg:max-h-10'
									: item.largeLogo
										? isTechEducation
											? 'mx-auto block h-8 w-full max-h-8 max-w-[76%] object-contain object-center sm:h-9 sm:w-auto sm:max-h-9 sm:max-w-[80%] lg:h-10 lg:max-h-10 lg:max-w-[82%]'
											: 'mx-auto block h-[3.25rem] w-full max-h-[3.25rem] max-w-full object-contain object-center sm:h-14 sm:w-auto sm:max-h-14 sm:max-w-full lg:h-16 lg:max-h-16'
										: isTechEducation
											? 'mx-auto block h-8 w-full max-h-8 max-w-[76%] object-contain object-center sm:h-9 sm:w-auto sm:max-h-9 sm:max-w-[80%] lg:h-10 lg:max-h-10 lg:max-w-[82%]'
											: 'mx-auto block h-[3.25rem] w-full max-h-[3.25rem] max-w-full object-contain object-center sm:h-12 sm:w-auto sm:max-h-12 sm:max-w-full lg:h-14 lg:max-h-14';
								if (isTechEducation && isIbmOrCoursera) {
									imgClass =
										'mx-auto block h-10 w-auto max-h-10 max-w-[92%] object-contain object-center sm:h-9 sm:w-auto sm:max-h-9 sm:max-w-[80%] lg:h-10 lg:max-h-10 lg:max-w-[82%]';
								}
								if (isTechEducation && isLarsen) {
									imgClass =
										'mx-auto block h-10 w-auto max-h-10 max-w-[90%] object-contain object-center sm:h-9 sm:w-auto sm:max-h- sm:max-w-[80%] lg:h-10 lg:max-h-10 lg:max-w-[82%]';
								}
								const inner = (
									<span class="partner-logo-slot flex h-full w-full min-h-0 min-w-0 items-center justify-center overflow-hidden">
										<img
											src={src}
											alt=""
											class={imgClass}
											loading="eager"
											decoding="async"
										/>
									</span>
								);
									return (
										<li class="flex min-h-0 w-full min-w-0 rounded-md">
											{item.href ? (
												<a
													href={item.href}
													class:list={[
														'partner-logo-link flex w-full min-w-0 max-w-full items-center justify-center overflow-hidden rounded-md transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400',
														cellFrame,
													]}
													target="_blank"
													rel="noopener noreferrer"
													aria-label={`${item.name} (opens in new tab)`}
												>
													{inner}
												</a>
											) : (
												<span
													class:list={[cellFrame, 'max-w-full overflow-hidden']}
													role="img"
													aria-label={`${item.name} logo`}
												>
													{inner}
												</span>
											)}
										</li>
									);
								})}
							</ul>
						</div>
					))}
				</div>
			)
		}
	</div>
</section>
