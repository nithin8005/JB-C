---
import { withBase } from '../../lib/withBase';

interface Initiative {
	title: string;
	body: string;
	image?: string;
	imageAlt?: string;
}

interface Metric {
	value: string;
	label: string;
}

interface Props {
	title: string;
	intro: string;
	heroImage?: string;
	heroImageAlt?: string;
	initiatives: Initiative[];
	commitmentTitle: string;
	commitmentParagraphs: [string, string];
	commitmentImage?: string;
	commitmentImageAlt?: string;
	metrics: Metric[];
}

const {
	title,
	intro,
	heroImage,
	heroImageAlt,
	initiatives,
	commitmentTitle,
	commitmentParagraphs,
	commitmentImage,
	commitmentImageAlt,
	metrics,
} = Astro.props;

const heroImageUrl = heroImage?.trim() ? withBase(heroImage.trim()) : '';
const commitmentImageUrl = commitmentImage?.trim() ? withBase(commitmentImage.trim()) : '';
---

<div class="flex flex-col-reverse">
<section id="sustainability" class="border-b border-neutral-200/90 bg-stone-50">
	<div class="mx-auto max-w-6xl px-5 py-10 sm:px-8 lg:px-12 lg:py-14">
		{
			heroImageUrl && (
				<div class="mt-8 aspect-21/9 min-h-[140px] w-full overflow-hidden rounded-lg border border-neutral-200/90 bg-neutral-100 shadow-sm sm:min-h-[180px] lg:mt-10">
					<img
						src={heroImageUrl}
						alt={heroImageAlt ?? ''}
						class="h-full w-full object-cover object-center"
						loading="lazy"
						decoding="async"
					/>
				</div>
			)
		}

		<p class="text-sm leading-relaxed text-neutral-600 sm:text-base">
			Our ESG priorities are translated into practical operating actions across each portfolio company.
		</p>

		<div class="mt-6 grid gap-5 sm:gap-6 md:grid-cols-3 lg:mt-8">
			{
				initiatives.map((item, i) => (
					<article
						class="flex flex-col rounded-lg border border-neutral-200/90 bg-stone-50 shadow-none transition hover:border-neutral-300"
					>
						<div class="flex flex-1 flex-col p-5">
							<h3 class="font-display text-lg font-medium text-neutral-900">{item.title}</h3>
							<p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">{item.body}</p>
						</div>
					</article>
				))
			}
		</div>

		<!-- Commitment: text overlaid on image (Real Assets–style hero, not stacked white block) -->
		<div class="mt-10 overflow-hidden rounded-lg border border-neutral-200/90 shadow-sm lg:mt-12">
			<div
				class="relative min-h-[min(22rem,78vw)] overflow-hidden bg-neutral-900 sm:min-h-[26rem] lg:min-h-[30rem]"
			>
				<div class="absolute inset-0 bg-neutral-800" aria-hidden="true" />
				{
					commitmentImageUrl ? (
						<img
							src={commitmentImageUrl}
							alt={commitmentImageAlt ?? ''}
							class="absolute inset-0 z-[1] h-full w-full object-cover object-center"
							loading="lazy"
							decoding="async"
						/>
					) : (
						<div
							class="absolute inset-0 z-[1] bg-[linear-gradient(145deg,#1c2833_0%,#334155_45%,#1e293b_100%)]"
							aria-hidden="true"
						/>
					)
				}
				<div
					class="pointer-events-none absolute inset-0 z-[2] bg-gradient-to-t from-black/85 via-black/55 to-black/35 sm:bg-gradient-to-r sm:from-black/82 sm:via-black/50 sm:to-black/25"
					aria-hidden="true"
				/>
				<div class="relative z-10 mx-auto max-w-6xl px-5 py-12 sm:px-8 sm:py-14 lg:px-12 lg:py-16">
					<div data-reveal class="max-w-3xl">
						<h3
							class="font-display text-[clamp(1.5rem,3.2vw,2.35rem)] font-medium leading-[1.12] tracking-tight text-balance text-white"
						>
							{commitmentTitle}
						</h3>
						<div class="mt-5 grid gap-4 text-sm leading-relaxed text-white/88 sm:gap-5 sm:text-base">
							<p>{commitmentParagraphs[0]}</p>
							<p>{commitmentParagraphs[1]}</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<ul class="mt-8 grid gap-2 sm:grid-cols-3 sm:gap-3 lg:mt-10">
			{
				metrics.map((m) => (
					<li class="rounded-lg border border-neutral-200/90 bg-white px-3 py-3.5 text-center shadow-sm sm:py-4">
						<p class="text-lg font-semibold tabular-nums text-neutral-900 sm:text-xl">{m.value}</p>
						<p class="mt-1 text-[10px] font-medium leading-snug text-neutral-600 sm:text-xs">{m.label}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>

<section id="esg-framework" class="relative overflow-hidden border-b border-neutral-200/90 bg-stone-50">
	<div
		class="pointer-events-none absolute inset-0 opacity-[0.05]"
		style="background-image: linear-gradient(rgba(38, 38, 38, 0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(38, 38, 38, 0.2) 1px, transparent 1px); background-size: 36px 36px;"
		aria-hidden="true"
	/>
	<div class="relative mx-auto max-w-7xl px-5 py-12 sm:px-8 lg:px-12 lg:py-16">
		<div class="grid gap-10 lg:grid-cols-2 lg:gap-12">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">ESG Framework</p>
				<h2 class="mt-3 max-w-2xl font-display text-[clamp(2rem,4.2vw,3.4rem)] font-light leading-[1.08] tracking-tight text-neutral-900">
					Sustainability is our <em class="font-display italic text-neutral-700">core thesis</em>
				</h2>
				<p class="mt-4 max-w-xl text-sm leading-relaxed text-neutral-600 sm:text-base">
					We embed ESG principles into sourcing, diligence, ownership, and exit planning so each investment compounds value
					responsibly over the long term.
				</p>
			</div>
			<blockquote class="border-l border-neutral-300 pl-5 font-display text-[clamp(1.35rem,2.6vw,2.1rem)] italic leading-snug text-neutral-700">
				“Disciplined sustainability practices are not an overlay - they are a driver of stronger outcomes for companies, communities,
				and capital partners.”
			</blockquote>
		</div>

		<div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
			<article class="group relative overflow-hidden rounded-lg border border-neutral-200/90 bg-white p-5 transition-colors hover:bg-neutral-50">
				<span class="pointer-events-none absolute right-4 top-3 font-display text-6xl font-semibold leading-none text-neutral-200">E</span>
				<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-neutral-500">Environmental</p>
				<h3 class="mt-2 font-display text-2xl font-medium leading-tight text-neutral-900">Planet-Positive Capital</h3>
				<p class="mt-3 text-sm leading-relaxed text-neutral-600">
					We invest behind operating models that decarbonize growth while improving resource efficiency and resilience.
				</p>
				<ul class="mt-4 space-y-2">
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Carbon neutrality target by 2035</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />100% renewable energy plans</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Annual impact reporting</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Zero deforestation policy</li>
				</ul>
			</article>

			<article class="group relative overflow-hidden rounded-lg border border-neutral-200/90 bg-white p-5 transition-colors hover:bg-neutral-50">
				<span class="pointer-events-none absolute right-4 top-3 font-display text-6xl font-semibold leading-none text-neutral-200">S</span>
				<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-neutral-500">Social</p>
				<h3 class="mt-2 font-display text-2xl font-medium leading-tight text-neutral-900">People-First Growth</h3>
				<p class="mt-3 text-sm leading-relaxed text-neutral-600">
					We prioritize inclusive workplaces and shared prosperity to strengthen execution and long-run company performance.
				</p>
				<ul class="mt-4 space-y-2">
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />40% diverse leadership target</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Living wage commitments</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Community investment programs</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Employee ownership plans</li>
				</ul>
			</article>

			<article class="group relative overflow-hidden rounded-lg border border-neutral-200/90 bg-white p-5 transition-colors hover:bg-neutral-50 md:col-span-2 xl:col-span-1">
				<span class="pointer-events-none absolute right-4 top-3 font-display text-6xl font-semibold leading-none text-neutral-200">G</span>
				<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-neutral-500">Governance</p>
				<h3 class="mt-2 font-display text-2xl font-medium leading-tight text-neutral-900">Principled Stewardship</h3>
				<p class="mt-3 text-sm leading-relaxed text-neutral-600">
					We maintain robust governance standards that reinforce accountability, transparency, and ethical decision-making.
				</p>
				<ul class="mt-4 space-y-2">
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Independent board representation</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Anti-corruption frameworks</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Quarterly LP transparency reports</li>
					<li class="flex items-start gap-2 text-sm text-neutral-700"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-neutral-500" />Whistleblower protection</li>
				</ul>
			</article>
		</div>

		<div class="mt-10 grid overflow-hidden rounded-lg border border-neutral-200/90 bg-white sm:grid-cols-2 xl:grid-cols-4">
			<div class="border-b border-neutral-200/90 px-5 py-4 sm:border-b-0 sm:border-r">
				<p class="font-display text-3xl font-medium text-neutral-900">Net Zero</p>
				<p class="mt-1 text-[11px] uppercase tracking-[0.14em] text-neutral-500">Portfolio target by 2035</p>
			</div>
			<div class="border-b border-neutral-200/90 px-5 py-4 xl:border-b-0 xl:border-r">
				<p class="font-display text-3xl font-medium text-neutral-900">40%</p>
				<p class="mt-1 text-[11px] uppercase tracking-[0.14em] text-neutral-500">Diverse leadership target</p>
			</div>
			<div class="border-b border-neutral-200/90 px-5 py-4 sm:border-b-0 sm:border-r">
				<p class="font-display text-3xl font-medium text-neutral-900">100%</p>
				<p class="mt-1 text-[11px] uppercase tracking-[0.14em] text-neutral-500">Renewable energy transition plans</p>
			</div>
			<div class="px-5 py-4">
				<p class="font-display text-3xl font-medium text-neutral-900">$120M</p>
				<p class="mt-1 text-[11px] uppercase tracking-[0.14em] text-neutral-500">Committed impact-linked capital</p>
			</div>
		</div>
	</div>
</section>
</div>
