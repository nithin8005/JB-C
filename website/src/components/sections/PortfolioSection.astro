---
import { withBase } from '../../lib/withBase';

interface Company {
	name: string;
	industry: string;
	description: string;
	logo?: string;
	href?: string;
}

interface Props {
	title: string;
	intro: string;
	/** Short line under the Portfolio heading (e.g. companies you build and invest in). */
	subtitle?: string;
	companies: Company[];
	videoMp4?: string;
	videoPoster?: string;
	heroBackground?: string;
	heroHeadline?: string;
	heroTagline?: string;
}

const {
	title,
	intro,
	subtitle,
	companies,
	videoMp4,
	videoPoster,
	heroBackground,
	heroHeadline,
	heroTagline,
} = Astro.props;

const portfolioTagline = subtitle?.trim() || 'Companies we build and invest in';

const hasHeroVideo = Boolean(videoMp4?.trim());
const hasHero = Boolean(hasHeroVideo || heroBackground);
const heroVideoUrl = videoMp4?.trim() ? withBase(videoMp4.trim()) : '';
const heroPosterUrl = videoPoster?.trim() ? withBase(videoPoster.trim()) : undefined;
const heroBackgroundUrl = heroBackground ? withBase(heroBackground) : '';
const headline = heroHeadline ?? title;
const tagline = heroTagline ?? intro;

const cardClass =
	'flex flex-col rounded-lg border border-neutral-200/90 bg-stone-50/60 p-4 shadow-sm transition-[border-color,box-shadow,transform] duration-300 hover:-translate-y-0.5 hover:border-neutral-300 hover:shadow-md sm:p-5';
---

<section id="portfolio" class="scroll-mt-20 border-b border-neutral-200/90 bg-white">
	{
		hasHero ? (
			<div class="relative min-h-[min(22rem,52vh)] overflow-hidden sm:min-h-[min(26rem,56vh)]">
				{
					hasHeroVideo ? (
						<>
							<div class="absolute inset-0 bg-slate-900" aria-hidden="true" />
							<video
								class="absolute inset-0 h-full w-full object-cover object-center"
								autoplay
								muted
								loop
								playsinline
								disablepictureinpicture
								preload="metadata"
								poster={heroPosterUrl}
								aria-hidden="true"
							>
								<source src={heroVideoUrl} type="video/mp4" />
							</video>
						</>
					) : (
						<img
							src={heroBackgroundUrl}
							alt=""
							class="absolute inset-0 h-full w-full object-cover object-[55%_center] sm:object-center"
							loading="eager"
							decoding="async"
							fetchpriority="high"
							aria-hidden="true"
						/>
					)
				}
				<div
					class="pointer-events-none absolute inset-0 bg-linear-to-r from-slate-950/95 via-slate-950/80 to-slate-950/35 sm:from-slate-950 sm:via-slate-950/75 sm:to-transparent"
					aria-hidden="true"
				/>
				<div class="relative z-10 mx-auto max-w-6xl px-5 py-14 sm:px-8 sm:py-16 lg:px-12 lg:py-20">
					<div data-reveal class="max-w-2xl">
						<h1
							class="font-display text-[clamp(2rem,4.5vw,3.25rem)] font-medium leading-[1.1] tracking-tight text-white"
							data-reveal-child
							style="--reveal-delay: 0ms"
						>
							{headline}
						</h1>
						<p
							class="mt-4 max-w-xl text-base leading-relaxed text-white/88 sm:text-lg"
							data-reveal-child
							style="--reveal-delay: 80ms"
						>
							{tagline}
						</p>
					</div>
				</div>
			</div>
		) : null
	}

	<div
		class:list={['mx-auto max-w-6xl px-5 sm:px-8 lg:px-12', hasHero ? 'py-12 lg:py-14' : 'py-10 lg:py-14']}
		data-reveal
	>
		{
			!hasHero ? (
				<>
					<h2
						class="font-display text-2xl font-medium text-neutral-900 sm:text-3xl"
						data-reveal-child
						style="--reveal-delay: 0ms"
					>
						{title}
					</h2>
					<p
						class="mt-2.5 max-w-2xl text-sm leading-relaxed text-neutral-600 sm:text-base"
						data-reveal-child
						style="--reveal-delay: 70ms"
					>
						{portfolioTagline}
					</p>
				</>
			) : (
				<div data-reveal-child style="--reveal-delay: 0ms">
					<h2 class="font-display text-xl font-medium text-neutral-900 sm:text-2xl">{portfolioTagline}</h2>
				</div>
			)
		}
		<div class:list={['grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3', hasHero ? 'mt-8' : 'mt-6']}>
			{
				companies.map((c, i) => {
					const logoUrl = c.logo ? withBase(c.logo) : '';
					const logoBlock = logoUrl ? (
						<div class="mb-3 flex h-11 items-center">
							<img
								src={logoUrl}
								alt=""
								class="max-h-10 w-auto max-w-[140px] object-contain object-left"
								loading="lazy"
								decoding="async"
							/>
						</div>
					) : (
						<div class="mb-3 h-9 w-9 rounded border border-neutral-200/90 bg-neutral-100" aria-hidden="true" />
					);

					const body = (
						<>
							{logoBlock}
							<h3 class="font-display text-lg font-medium text-neutral-900">{c.name}</h3>
							<p class="mt-1 text-xs font-semibold uppercase tracking-wider text-neutral-500">{c.industry}</p>
							<p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">{c.description}</p>
							{c.href && (
								<p class="mt-3 text-xs font-medium text-neutral-900 underline-offset-2 group-hover:underline">
									Visit site →
								</p>
							)}
						</>
					);

					const external = Boolean(c.href?.startsWith('http'));

					const revealDelay = `--reveal-delay: ${95 + i * 55}ms`;

					return c.href ? (
						<a
							href={withBase(c.href)}
							class:list={[cardClass, 'group text-inherit no-underline outline-none ring-neutral-800 focus-visible:ring-2']}
							data-reveal-child
							style={revealDelay}
							target={external ? '_blank' : undefined}
							rel={external ? 'noopener noreferrer' : undefined}
						>
							{body}
						</a>
					) : (
						<article class={cardClass} data-reveal-child style={revealDelay}>
							{body}
						</article>
					);
				})
			}
		</div>
	</div>
</section>

