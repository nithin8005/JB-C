---
interface Props {
	title: string;
	intro: string;
	email: string;
}

const { title, intro, email } = Astro.props;

const mailto = `mailto:${email}`;
---

<section id="contact" class="scroll-mt-20 border-b border-neutral-200/50">
	<!-- Editorial hero: paper tone + faint blueprint grid -->
	<div class="contact-paper-hero relative isolate min-h-[min(34rem,92vh)] overflow-hidden">
		<div class="contact-paper-texture pointer-events-none absolute inset-0" aria-hidden="true"></div>
		<div class="contact-blueprint pointer-events-none absolute inset-0" aria-hidden="true"></div>
		<div
			class="relative z-10 mx-auto flex min-h-[min(34rem,92vh)] max-w-6xl flex-col justify-end px-5 pb-14 pt-28 sm:px-8 sm:pb-20 sm:pt-32 lg:px-12 lg:pb-24 lg:pt-36"
		>
			<div class="max-w-2xl">
				<h1 class="font-display text-[clamp(2.35rem,5vw,3.75rem)] font-semibold leading-[1.05] tracking-tight text-neutral-900">
					{title}
				</h1>
				<p class="mt-6 max-w-xl font-display text-base font-normal leading-[1.65] text-neutral-700 sm:text-lg">{intro}</p>
				<p class="mt-5 max-w-xl font-display text-base font-normal leading-[1.65] text-neutral-700 sm:text-lg">
					For general inquiries, please write to{' '}
					<a
						href={mailto}
						class="text-neutral-900 underline decoration-neutral-400 decoration-1 underline-offset-[3px] transition hover:decoration-neutral-900"
					>
						{email}
					</a>
					.
				</p>
				<div class="mt-10 flex flex-wrap items-center gap-4">
					<button
						type="button"
						id="contact-copy-email"
						class="group inline-flex items-center gap-3 border-0 bg-transparent p-0 text-left text-neutral-900"
						data-email={email}
						aria-label={`Copy ${email} to clipboard`}
					>
						<span
							class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-neutral-900 bg-neutral-900 text-white transition group-hover:bg-neutral-800"
							aria-hidden="true"
						>
							<svg class="h-3.5 w-3.5 -translate-x-px" viewBox="0 0 12 12" fill="none" aria-hidden="true">
								<path
									d="M4.5 2.5L8.5 6l-4 3.5"
									stroke="currentColor"
									stroke-width="1.4"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
							</svg>
						</span>
						<span class="border-b border-neutral-900 pb-0.5 text-sm font-medium tracking-wide transition group-hover:border-neutral-600 group-hover:text-neutral-700">
							Copy email address
						</span>
					</button>
					<span id="contact-copy-status" class="sr-only" role="status" aria-live="polite"></span>
				</div>
			</div>
		</div>
	</div>
	<!-- Visible confirmation (sr-only status above is for assistive tech) -->
	<div
		id="contact-copy-toast"
		class="pointer-events-none fixed bottom-8 left-1/2 z-100 -translate-x-1/2 whitespace-nowrap rounded-md border border-neutral-700/90 bg-neutral-900 px-4 py-2.5 text-sm font-medium text-white opacity-0 shadow-[0_4px_24px_rgba(0,0,0,0.2)] transition-opacity duration-200"
		role="status"
		aria-hidden="true"
	>
		Copied!
	</div>
</section>

<style>
	.contact-paper-hero {
		background-color: #ebe6df;
		background-image: linear-gradient(165deg, rgba(255, 255, 255, 0.55) 0%, transparent 42%, rgba(0, 0, 0, 0.03) 100%);
	}
	.contact-paper-texture {
		opacity: 0.35;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
		mix-blend-mode: multiply;
	}
	.contact-blueprint {
		opacity: 0.45;
		background-image: linear-gradient(rgba(60, 55, 50, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(60, 55, 50, 0.045) 1px, transparent 1px);
		background-size: 52px 52px;
		mask-image: linear-gradient(to bottom, black 0%, black 55%, transparent 100%);
	}
</style>

<script define:vars={{ email }}>
	(() => {
		const btn = document.getElementById('contact-copy-email');
		const status = document.getElementById('contact-copy-status');
		const toast = document.getElementById('contact-copy-toast');
		if (!btn || !status) return;
		const address = btn.getAttribute('data-email') || email;
		const TOAST_MS = 2000;
		/** @type {ReturnType<typeof setTimeout> | undefined} */
		let toastTimer;

		function showToast(message) {
			if (!toast) return;
			toast.textContent = message;
			toast.classList.remove('opacity-0');
			toast.classList.add('opacity-100');
			clearTimeout(toastTimer);
			toastTimer = setTimeout(() => {
				toast.classList.remove('opacity-100');
				toast.classList.add('opacity-0');
			}, TOAST_MS);
		}

		btn.addEventListener('click', async () => {
			try {
				await navigator.clipboard.writeText(address);
				status.textContent = 'Email copied to clipboard.';
				showToast('Copied!');
			} catch {
				status.textContent = 'Copy not supported; use the email link above.';
				showToast("Couldn't copy");
			}
			setTimeout(() => {
				status.textContent = '';
			}, TOAST_MS);
		});
	})();
</script>
