---
import { withBase } from '../../lib/withBase';

interface Props {
	heading?: string;
	/** Optional bullet list under the About column (homepage). */
	points?: string[];
	/** Path from site root (file under `website/public/`). */
	aboutImage?: string;
	aboutImageAlt?: string;
	/** Bold name, gray title, bullets (large photo stays in the left column only). */
	profile?: { name: string; title: string; roles: string[] };
}

const { heading, points: pointsProp, aboutImage, aboutImageAlt, profile } = Astro.props;
const points = (pointsProp ?? []).map((p) => p.trim()).filter(Boolean);
const usePoints = points.length > 0;
const headingText = heading?.trim();

const figureLabel = aboutImageAlt ?? 'About section image';
const aboutImageUrl = aboutImage ? withBase(aboutImage) : '';
---

<section id="about" class="scroll-mt-20 border-b border-neutral-200/90 bg-white">
	<div class="mx-auto max-w-7xl px-5 py-10 sm:px-8 lg:px-12 lg:py-14">
		{
			headingText ? (
				<h2 class="font-display text-2xl font-medium leading-tight tracking-tight text-neutral-900 sm:text-3xl">
					{headingText}
				</h2>
			) : null
		}
		<div
			data-reveal
			class:list={[
				'grid gap-6 sm:gap-8 lg:grid-cols-[auto_minmax(0,1fr)] lg:items-center lg:gap-x-6 xl:gap-x-8 lg:gap-y-0',
				headingText ? 'mt-6 lg:mt-8' : null,
			]}
		>
			<div
				class="order-1 flex min-w-0 shrink-0 justify-center lg:order-1 lg:justify-start"
				data-reveal-child
				style="--reveal-delay: 0ms"
			>
				{
					aboutImageUrl ? (
						<figure class="m-0 w-max max-w-xs sm:max-w-sm">
							<div class="aspect-3/2 w-full max-w-xs overflow-hidden rounded-2xl border border-neutral-200/90 bg-neutral-100 sm:max-w-sm sm:rounded-3xl">
								<img
									src={aboutImageUrl}
									alt={aboutImageAlt ?? ''}
									class="h-full w-full object-cover object-top"
									loading="lazy"
									decoding="async"
								/>
							</div>
							{aboutImageAlt ? <figcaption class="sr-only">{figureLabel}</figcaption> : null}
						</figure>
					) : (
						<div
							class="aspect-3/2 w-full max-w-xs overflow-hidden rounded-2xl border border-neutral-200/90 bg-neutral-100 sm:max-w-sm sm:rounded-3xl"
							aria-hidden="true"
						/>
					)
				}
			</div>
			<div
				class="order-2 flex min-w-0 w-full max-w-xl flex-col lg:order-2 lg:mt-0 lg:max-w-none"
				data-reveal-child
				style="--reveal-delay: 95ms"
			>
				<div class="about-prose text-sm leading-normal text-neutral-600 sm:text-base">
					<slot />
				</div>
				{
					profile && profile.roles.length > 0 ? (
						<div class="about-profile mt-4 sm:mt-5 lg:mt-3">
							<p class="font-sans text-base font-semibold tracking-tight text-neutral-900">{profile.name}</p>
							<p class="mt-0.5 text-sm leading-tight text-neutral-500">{profile.title}</p>
							<ul class="about-profile-roles mt-1.5 list-disc space-y-1 pl-5 text-sm leading-tight text-neutral-600 marker:text-neutral-400">
								{profile.roles.map((role) => (
									<li>{role}</li>
								))}
							</ul>
						</div>
					) : null
				}
				{
					usePoints ? (
						<ul class="about-highlights mt-4 list-disc space-y-1 pl-5 text-sm leading-tight text-neutral-600 marker:text-neutral-400 sm:mt-5 lg:mt-3">
							{points.map((line) => (
								<li>{line}</li>
							))}
						</ul>
					) : null
				}
			</div>
		</div>
	</div>
</section>

<style is:global>
	.about-prose > :not([hidden]) ~ :not([hidden]) {
		margin-top: 0.75rem;
	}
	.about-prose :where(p) {
		margin: 0;
		line-height: 1.5;
	}
	.about-prose :where(strong) {
		font-weight: 600;
		color: #171717;
	}
	.about-prose :where(a) {
		color: #171717;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.about-prose :where(ul) {
		margin: 0;
		padding-left: 1.25rem;
		list-style-type: disc;
	}
	.about-prose :where(li) {
		margin: 0.2rem 0;
		line-height: 1.45;
	}
	.about-prose :where(p + ul) {
		margin-top: 0.5rem;
	}
</style>
