---
interface Pillar {
	title: string;
	tagline: string;
	body: string;
	image: string;
	imageAlt: string;
	ctaLabel?: string;
	ctaHref?: string;
}

interface Props {
	heroHeadline: string;
	heroSubline: string;
	heroImage: string;
	heroImageAlt: string;
	pillars: Pillar[];
	closingHeadline: string;
	closingBody: string;
}

const { heroHeadline, heroSubline, heroImage, heroImageAlt, pillars, closingHeadline, closingBody } = Astro.props;

const heroSrc = heroImage.trim();
const pillarsTrimmed = pillars.map((p) => ({ ...p, image: p.image.trim() }));
---

<section id="real-assets-hero" class="relative overflow-hidden border-b border-neutral-200/90 bg-neutral-900">
	<div class="absolute inset-0 bg-neutral-800" aria-hidden="true" />
	<img
		src={heroSrc}
		alt={heroImageAlt}
		class="absolute inset-0 z-[1] h-full w-full object-cover object-center"
		loading="eager"
		decoding="async"
		fetchpriority="high"
		referrerpolicy="no-referrer"
	/>
	<div
		class="pointer-events-none absolute inset-0 z-[2] bg-gradient-to-t from-black/85 via-black/55 to-black/35 sm:bg-gradient-to-r sm:from-black/80 sm:via-black/50 sm:to-black/20"
		aria-hidden="true"
	/>
	<div class="relative z-10 mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">
		<div data-reveal class="max-w-3xl">
			<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/70">Real Assets</p>
			<h1 class="mt-3 font-display text-[clamp(2rem,4.5vw,3.5rem)] font-medium leading-[1.08] tracking-tight text-white text-balance">
				{heroHeadline}
			</h1>
			<p class="mt-5 max-w-2xl text-base leading-relaxed text-white/88 sm:text-lg">{heroSubline}</p>
		</div>
	</div>
</section>

{
	pillarsTrimmed.map((pillar, i) => {
		const imageFirst = i % 2 === 0;
		return (
			<section class="scroll-mt-20 border-b border-neutral-200/90 bg-white" aria-labelledby={`ra-pillar-${i}`}>
				<div
					data-reveal
					class="mx-auto grid max-w-7xl lg:grid-cols-2 lg:items-stretch"
				>
					<div
						class:list={[
							'relative min-h-[min(18rem,52vw)] bg-neutral-900 lg:min-h-[22rem]',
							/* Mobile: headline before image. Desktop even: image | text; odd: text | image */
							imageFirst ? 'order-2 lg:order-1' : 'order-2',
						]}
						data-reveal-child
						style="--reveal-delay: 0ms"
					>
						<div class="absolute inset-0 bg-neutral-800" aria-hidden="true" />
						<img
							src={pillar.image}
							alt={pillar.imageAlt}
							class="absolute inset-0 z-[1] h-full w-full object-cover"
							loading="lazy"
							decoding="async"
							referrerpolicy="no-referrer"
						/>
						<div class="pointer-events-none absolute inset-0 z-[2] bg-gradient-to-t from-black/25 to-transparent lg:bg-gradient-to-r lg:from-black/20 lg:to-transparent" aria-hidden="true" />
					</div>
					<div
						class:list={[
							'flex flex-col justify-center px-5 py-12 sm:px-8 sm:py-14 lg:px-12 lg:py-16',
							imageFirst ? 'order-1 lg:order-2' : 'order-1',
						]}
						data-reveal-child
						style="--reveal-delay: 90ms"
					>
						<h2 id={`ra-pillar-${i}`} class="font-display text-2xl font-medium tracking-tight text-neutral-900 sm:text-3xl">
							{pillar.title}
						</h2>
						<p class="mt-2 text-sm font-medium tracking-wide text-neutral-500 sm:text-base">{pillar.tagline}</p>
						<p class="mt-5 text-sm leading-relaxed text-neutral-600 sm:text-base">{pillar.body}</p>
						{
							pillar.ctaLabel && pillar.ctaHref ? (
								<a
									href={pillar.ctaHref}
									class="mt-6 inline-flex w-fit border-b border-neutral-900 pb-0.5 text-sm font-medium text-neutral-900 transition hover:border-neutral-600 hover:text-neutral-700"
								>
									{pillar.ctaLabel}
								</a>
							) : null
						}
					</div>
				</div>
			</section>
		);
	})
}

<section class="border-b border-neutral-200/90 bg-stone-50">
	<div class="mx-auto max-w-3xl px-5 py-14 text-center sm:px-8 sm:py-16 lg:px-12 lg:py-20" data-reveal>
		<h2 class="font-display text-2xl font-medium tracking-tight text-neutral-900 sm:text-3xl">
			{closingHeadline}
		</h2>
		<p class="mt-5 text-sm leading-relaxed text-neutral-600 sm:text-base">{closingBody}</p>
	</div>
</section>
